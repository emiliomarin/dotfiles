{
    "[dockercompose]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "advanced",
        "editor.quickSuggestions": {
            "other": true,
            "comments": false,
            "strings": true
        },
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "[dockerfile]": {
        "editor.defaultFormatter": "ms-azuretools.vscode-docker"
    },
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[markdown]": {
        "editor.defaultFormatter": "yzhang.markdown-all-in-one"
    },
    "[proto3]": {
        "editor.defaultFormatter": "bufbuild.vscode-buf"
    },
    "[sql]": {
        "editor.defaultFormatter": "mtxr.sqltools",
        "editor.formatOnSave": false
    },
    "[toml]": {
        "editor.formatOnSave": false
    },
    "[go]": {
        "editor.defaultFormatter": "golang.go",
        "editor.formatOnSave": true
    },
    "diffEditor.codeLens": true,
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.accessibilitySupport": "off",
    "editor.bracketPairColorization.enabled": true,
    "editor.fontFamily": "MesloLGS Nerd Font",
    "editor.fontSize": 12,
    "editor.guides.bracketPairs": true,
    "editor.inlineSuggest.enabled": true,
    "editor.largeFileOptimizations": false,
    "editor.minimap.enabled": false,
    "editor.renderWhitespace": "all",
    "editor.rulers": [
        140
    ],
    "errorLens.excludeBySource": [
        "cSpell"
    ],
    "explorer.fileNesting.enabled": true,
    "files.associations": {
        "*.yml": "dockercompose"
    },
    "files.insertFinalNewline": true,
    "git.autofetch": true,
    "git.confirmSync": false,
    "git.mergeEditor": true,
    "githubPullRequests.pullBranch": "never",
    "go.coverOnSingleTest": true,
    "go.coverOnSingleTestFile": true,
    "go.editorContextMenuCommands": {
        "fillStruct": true
    },
    "go.toolsEnvVars": {
        "PATH": "/opt/homebrew/bin:${env:PATH}",
        "GOIMPORTSLOCAL": "github.com/SWORDHealth"
    },
    "go.inlayHints.compositeLiteralFields": true,
    "go.inlayHints.parameterNames": true,
    "go.lintTool": "golangci-lint",
    "go.lintFlags": [
        "--fast-only",
        "--config=${workspaceFolder}/.golangci.yml",
    ],
    // "go.lintFlags": [
    //     "--path-mode=abs",
    //     "--config=${workspaceFolder}/.golangci.yaml",
    //     "--fast-only"
    // ],
    "go.lintOnSave": "file",
    "go.toolsManagement.autoUpdate": true,
    "go.useLanguageServer": true,
    "go.testTimeout": "10s",
    "gopls": {
        "local": "github.com/SWORDHealth",
        "formatting.goimports": true,
        "ui.navigation.importShortcut": "Definition",
        "ui.semanticTokens": true,
        "verboseOutput": true,
        "formatting.formatTool": "goimports",
        "env": {
            "GOIMPORTSLOCAL": "github.com/SWORDHealth"
        }
    },
    "go.languageServerFlags": [
        "-remote=auto"
    ],
    "go.languageServerExperimentalFeatures": {
        "format": true
    },
    "makefile.configureOnOpen": false,
    "redhat.telemetry.enabled": false,
    "terminal.external.osxExec": "Warp.app",
    "window.commandCenter": false,
    "workbench.colorCustomizations": {
        "[Quiet Light]": {
            "gitDecoration.modifiedResourceForeground": "#0404ff",
            "gitDecoration.conflictingResourceForeground": "#cdff04",
            "list.errorForeground": "#f00505",
            "list.warningForeground": "#01b5b2"
        }
    },
    "workbench.editor.empty.hint": "hidden",
    "workbench.startupEditor": "none",
    "workbench.tree.indent": 14,
    "workbench.tree.renderIndentGuides": "always",
    "workbench.colorTheme": "Solarized Dark",
    "terminal.integrated.fontFamily": "MesloLGS Nerd Font",
    "terminal.integrated.fontSize": 12,
    "terminal.explorerKind": "external",
    "terminal.integrated.defaultProfile.osx": "zsh",
    "docker.extension.enableComposeLanguageServer": false,
    "go.gopath": "",
    "editor.defaultFormatter": "golang.go",
    "editor.formatOnSave": true,
    "terminal.integrated.scrollback": 10000,
    "go.testEnvVars": {
        "RUNNING_TESTS": true,
        "APP_DEBUG": true,
        "MYSQL_SSL_CERTIFICATES": "/var/secrets/mysql",
        "TESTRESOURCE_MYSQL_DSN": "test:test@tcp(localhost:3309)/"
    },
    "workbench.settings.applyToAllProfiles": [],
    "[github-actions-workflow]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "cursor.composer.shouldChimeAfterChatFinishes": true,
    "cursor.composer.usageSummaryDisplay": "always",
    "claudeCode.preferredLocation": "panel"
}
